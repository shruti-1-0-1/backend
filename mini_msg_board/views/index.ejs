<h1><%= title %></h1>

<a href="/new">Create Message</a>

<% messages.forEach((message, index) => { %>

    <h2><%= message.user %></h2>

    <p><%= message.text %></p>

    <small>
        <%= message.added %>
    </small>

    <br>

    <a href="/message/<%= index %>">
        Open
    </a>

    <hr>

<% }) %>
