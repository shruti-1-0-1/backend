<h1>New Message</h1>

<form method="POST" action="/new">

    <input
        type="text"
        name="messageUser"
        placeholder="Your Name"
    >

    <br><br>

    <input
        type="text"
        name="messageText"
        placeholder="Message"
    >

    <br><br>

    <button type="submit">
        Submit
    </button>

</form>
